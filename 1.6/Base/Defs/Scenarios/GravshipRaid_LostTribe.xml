<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--
    Not ParentName="LostTribe": inheriting the vanilla scenario would drag along its hidden
    ScenPart_PlayerPawnsArriveMethod (Standing) part and produce a duplicate arrival. This scenario builds
    the same tribal loadout from ScenarioBase instead, with GR_CrashlandedGravshipStart as its only
    arrival part.
  -->
  <ScenarioDef ParentName="ScenarioBase">
    <defName>GR_LostTribe</defName>
    <label>Lost Tribe (Gravship Raids)</label>
    <description>Your tribe was destroyed in a night raid by a hostile faction with weapons and machines beyond anything your people had ever faced. Five of you escaped aboard a gravship stolen in the chaos - but its gravlite core failed over this rimworld, and the hull came apart on the way down. Now, it's time to build up a new home.\n\nNote: Since you'll start poor and lack technology, this is a difficult scenario.</description>
    <scenario>
      <summary>Five lost tribespeople emerge from a wrecked gravship and attempt to rebuild. Difficult.</summary>
      <playerFaction>
        <factionDef>PlayerTribe</factionDef>
      </playerFaction>
      <parts>

        <!-- Config pages -->
        <li Class="ScenPart_ConfigPage_ConfigureStartingPawns">
          <def>ConfigPage_ConfigureStartingPawns</def>
          <pawnCount>5</pawnCount>
          <pawnChoiceCount>8</pawnChoiceCount>
        </li>

        <!-- Player starting stuff spawn method: the wrecked gravship itself, not vanilla standing arrival -->
        <li Class="Gravship_Raids.ScenPart_CrashlandedGravshipStart">
          <def>GR_CrashlandedGravshipStart</def>
          <visible>false</visible>
          <prefab>GR_Prefab_LostTribeGravship</prefab>
        </li>

        <!-- Player pawns modifiers (identical to vanilla Lost Tribe) -->
        <li Class="ScenPart_ForcedHediff">
          <def>ForcedHediff</def>
          <visible>false</visible>
          <context>PlayerStarter</context>
          <chance>0.5</chance>
          <hediff>Malnutrition</hediff>
          <severityRange>0.2~0.4</severityRange>
        </li>
        <li Class="ScenPart_SetNeedLevel">
          <def>SetNeedLevel</def>
          <visible>false</visible>
          <context>PlayerStarter</context>
          <chance>1.0</chance>
          <need>Food</need>
          <levelRange>0~0.1</levelRange>
        </li>

        <!-- Player starting things (identical to vanilla Lost Tribe) -->
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Silver</thingDef>
          <count>200</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Pemmican</thingDef>
          <count>400</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MedicineHerbal</thingDef>
          <count>20</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MeleeWeapon_Club</thingDef>
          <stuff>WoodLog</stuff>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MeleeWeapon_Ikwa</thingDef>
          <stuff>Steel</stuff>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MeleeWeapon_Knife</thingDef>
          <stuff>Jade</stuff>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Bow_Short</thingDef>
          <count>2</count>
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Pila</thingDef>
        </li>
        <li Class="ScenPart_StartingAnimal">
          <def>StartingAnimal</def>
          <count>3</count>
          <bondToRandomPlayerPawnChance>1.0</bondToRandomPlayerPawnChance>
        </li>

        <!-- Scatter some things near player start -->
        <li Class="ScenPart_ScatterThingsNearPlayerStart">
          <def>ScatterThingsNearPlayerStart</def>
          <thingDef>WoodLog</thingDef>
          <count>500</count>
        </li>

        <!-- Game start dialog -->
        <li Class="ScenPart_GameStartDialog">
          <def>GameStartDialog</def>
          <textKey>GravshipRaids.LostTribe.GameStartDialogText</textKey>
          <closeSound>GameStartSting</closeSound>
        </li>

      </parts>
    </scenario>
  </ScenarioDef>

</Defs>
